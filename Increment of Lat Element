import java.util.*;

public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
	    int n=sc.nextInt();
	    List<Integer> list=new ArrayList<>();
		for(int i=0;i<n;i++){
		    list.add(sc.nextInt());
		}
		for(int i=list.size()-1;i>=0;i--){
		    if(list.get(i)<9){
		        list.set(i,list.get(i)+1);
		break;
		    }else{
		        list.set(i,0);
		        
		    }
		}
		if(list.get(0)==0){
		    list.add(0,1);
		}
		System.out.println(list);
	}
}
